# Canvas 配置
CANVAS_BASE_URL=https://canvas.sufe.edu.cn/

# 数据库配置
DATABASE_URL=mysql://root:password@localhost:3307/canvas_helper

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 文件存储配置
# 生产建议使用绝对路径，并确保运行后端的用户有读写权限。
FILE_STORAGE_DIR=/var/lib/canvasbot/files

# 文件后台下载 worker。多实例部署时，只在专门的 worker 进程开启。
FILE_WORKER_ENABLED=true

# ========================================
# Agent 配置（Coze AI）
# ========================================
# Coze API Token（必填）
COZE_API_TOKEN="pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Coze API 基础地址
COZE_BASE_URL="https://api.coze.cn"

# Agent Bot 白名单。前端可以传 botId，但必须在后端允许列表中。
COZE_BOT_ID="7582959222351167524"
COZE_PPT_BOT_ID="7582988139266998307"
COZE_ALLOWED_BOT_IDS="7582959222351167524,7582988139266998307"

# Agent 简单限流（每个 Canvas token 每窗口请求数）
AGENT_RATE_LIMIT_MAX=20
AGENT_RATE_LIMIT_WINDOW_MS=60000

# Agent 上传文件大小上限和审计日志保留天数
AGENT_UPLOAD_MAX_BYTES=52428800
AGENT_LOG_RETENTION_DAYS=90

# 文件后台下载大小上限（默认 100MB）
FILE_DOWNLOAD_MAX_BYTES=104857600

# 可选：服务器端口
PORT=3000

# CORS 配置：允许的前端域名（多个用逗号分隔）
# 本地开发已自动包含 localhost:3000,3001,3002,5173 和 127.0.0.1
# 部署到服务器时，在这里添加你的前端域名
# 示例：ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=

# 仅本地临时调试时可设为 true，允许未列入 ALLOWED_ORIGINS 的开发来源
ALLOW_UNLISTED_DEV_ORIGINS=false

# 环境配置
# 部署时请设置为 production，并确保在生产环境中正确配置 ALLOWED_ORIGINS
NODE_ENV=development

# 是否启用请求日志（调试时设为 true）
ENABLE_REQUEST_LOGGING=false

# ========================================
# OAuth2 配置（暂时不需要，等获得 Developer Key 后配置）
# ========================================
# CANVAS_CLIENT_ID=your_client_id
# CANVAS_CLIENT_SECRET=your_client_secret
# CANVAS_REDIRECT_URI=http://localhost:3000/api/auth/callback
# CANVAS_OAUTH_AUTHORIZE_PATH=/login/oauth2/auth
# CANVAS_OAUTH_TOKEN_PATH=/login/oauth2/token
